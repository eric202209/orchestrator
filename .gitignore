# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
.env
*.egg-info/
dist/
build/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# SSL/TLS Certificates (SECURITY - NEVER COMMIT)
*.pem
*.key
cert.pem
key.pem
certs/

# Logs
*.log
logs/

# Testing
coverage/
.nyc_output/

# Misc
*.tar.gz
*.zip
*.bak
*.tmp
.cache/

# Development files (NEVER COMMIT)
.notes/
!notes/DEBUG_HISTORY.md
!notes/PHASES_PROGRESS.md
!notes/CORS_FIXES.md
!notes/TASK_TIMEOUT_FIX.md
!notes/HISTORICAL_DOCS_CLEANUP_SUMMARY.md
!tests/ERROR_HANDLER_FIX_SUMMARY.md
!tests/*.md
*.note
*.test

# All markdown files except README.md
*.md
!README.md

# Database files (NEVER COMMIT - contains sensitive data)
*.db
*.sqlite
*.sqlite3
*.db-journal
dump.rdb
*.rdb

# Scripts to stop services (should be run locally)
stop_all.sh
start_all.sh
restart_all.sh

# Configuration files in config/ directory (tracked)
config/*.conf
config/*.ini
config/*.cfg
config/README.md

# Ignore config directory except README.md and config files
!config/
!config/*.conf
!config/*.ini
!config/*.cfg
!config/README.md
