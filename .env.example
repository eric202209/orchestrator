# Orchestrator .env example
#
# Copy this file to .env, then edit only the values for your machine.
# Most new users only need sections 1-4.


# =============================================================================
# 1. Required Basics
# =============================================================================

PROJECT_NAME=AI Dev Agent Orchestrator
VERSION=0.1.0
HOST=0.0.0.0
PORT=8080

# Optional build/deployment identity diagnostics exposed at
# /api/v1/ops/build-identity. Set these before Docker rebuild validation when
# you need evidence that the running container matches the repo commit.
#
# Example:
#   export ORCHESTRATOR_GIT_SHA=$(git rev-parse HEAD)
#   export ORCHESTRATOR_REPO_GIT_SHA=$(git rev-parse HEAD)
#   export ORCHESTRATOR_BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ)
#   export ORCHESTRATOR_IMAGE_TAG=orchestrator:$(git rev-parse --short HEAD)
ORCHESTRATOR_GIT_SHA=
ORCHESTRATOR_REPO_GIT_SHA=
ORCHESTRATOR_BUILD_TIME=
ORCHESTRATOR_IMAGE_TAG=
ORCHESTRATOR_IMAGE_ID=
ORCHESTRATOR_CONFIG_SOURCE=.env

# Generate a real value before using this outside throwaway local testing:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me

# Host/native workspace root. Docker mounts this to /app/projects inside
# containers. Use a WSL ext4 path on Windows, not /mnt/c.
WORKSPACE_ROOT=/home/yourname/projects

# Leave unset unless you intentionally use another database.
# Default is sqlite:////path/to/orchestrator/orchestrator.db
# DATABASE_URL=


# =============================================================================
# 2. Pick One Runtime Setup
# =============================================================================

# Default developer setup: OpenClaw local control.
AGENT_BACKEND=local_openclaw
AGENT_MODEL=local
OPENCLAW_GATEWAY_URL=http://127.0.0.1:8000
OPENCLAW_API_KEY=
OPENCLAW_CLI_PATH=
OPENCLAW_CLI_ARGS=

# Windows laptop / compact local setup:
#   AGENT_BACKEND=direct_ollama
#   OLLAMA_AGENT_MODEL=qwen3:8b
#   RUNTIME_PROFILE=compact_local
#
# llama.cpp / LM Studio OpenAI-compatible setup:
#   AGENT_BACKEND=openai_responses_api
#   AGENT_MODEL=local
#   OPENAI_BASE_URL=http://host.docker.internal:8001/v1
#   OPENAI_API_KEY=dummy
#
# Hosted stronger lane setup:
#   AGENT_SECONDARY_BACKEND=openai_responses_api
#   OPENAI_API_KEY=<your key>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=


# =============================================================================
# 3. Machine Profile
# =============================================================================

# standard       = normal desktop/server defaults
# medium         = bounded local desktop profile
# low_resource   = constrained machine profile
# compact_local  = laptop validation profile for safe-stop/governed escalation
#
# Suggested:
# - 6GB VRAM / 16GB RAM laptop: compact_local
# - 16GB VRAM / 48GB RAM desktop: medium
# - 128GB RAM Ubuntu workstation/server: standard
RUNTIME_PROFILE=standard


# =============================================================================
# 4. Ollama Settings
# =============================================================================

# Used when AGENT_BACKEND=direct_ollama. Also used when the secondary lane is
# direct_ollama. Set this to a model that is already pulled on this machine.
# Examples:
#   6GB VRAM laptop: qwen3:8b
#   16GB+ VRAM desktop: qwen2.5-coder:14b or qwen2.5-coder:32b
#   Large Linux workstation: choose the validated local model for that host
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_AGENT_MODEL=
OLLAMA_NUM_CTX=4096

# Optional planning-only timeout for slower local planning models.
# Keep 0 for small models. For qwen2.5-coder:32b on a 16GB+ VRAM desktop,
# start around 300.
OLLAMA_PLANNING_TIMEOUT_SECONDS=0

# Embeddings for the knowledge layer.
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=0


# =============================================================================
# 5. Governed Escalation
# =============================================================================

# Optional stronger planning lane. It is used only after the operator explicitly
# selects "Retry with stronger planning lane".
#
# Practical laptop recommendation:
# - primary lane: direct_ollama + qwen3:8b
# - 6GB VRAM laptop: leave AGENT_SECONDARY_BACKEND blank
# - larger validation machine: set openai_responses_api or another hosted backend
#
# A second local Ollama model is useful for routing/fallback smoke tests, but it
# should not be treated as proof of a truly stronger lane on a 6GB VRAM laptop.
AGENT_SECONDARY_BACKEND=

# Optional role-specific backend overrides. Blank PLANNING_BACKEND and
# EXECUTION_BACKEND fall back to AGENT_BACKEND. Blank DEBUG_REPAIR_BACKEND falls
# back to REPAIR_BACKEND, then AGENT_BACKEND.
PLANNING_BACKEND=
EXECUTION_BACKEND=
REPAIR_BACKEND=
DEBUG_REPAIR_BACKEND=

# Optional role-specific model overrides. Blank values fall back to AGENT_MODEL
# or the selected backend default.
PLANNER_MODEL=
EXECUTION_MODEL=
DEBUG_REPAIR_MODEL=


# =============================================================================
# 6. Planning And Repair Policy
# =============================================================================

PLANNING_REPAIR_ENABLED=True
PLANNING_REPAIR_BASE_URL=http://ai-gateway:8000/v1
PLANNING_REPAIR_MODEL=qwen-local
PLANNING_REPAIR_API_KEY=
PLANNING_REPAIR_DISABLE_THINKING=True
PLANNING_REPAIR_TIMEOUT_SECONDS=90

# local_openclaw only: override the direct-planning and direct-repair wall-clock
# timeout when AGENT_BACKEND=local_openclaw (http://ai-gateway:8000).
#
# The default (0) falls back to PLANNING_REPAIR_TIMEOUT_SECONDS above.
# On local hardware the model is slower than a hosted API: a realistic
# Garden-Story-sized plan (8,900-char prompt, ~4,600-char output) takes ~155s
# at ~10 tok/s. Set this to 240 as a safe ceiling for local_openclaw backends.
# Leave at 0 for direct_ollama or hosted backends (those use their own timeouts).
#
# Note: this value is read from the .env file only if the environment variable
# PLANNING_DIRECT_LOCAL_OPENCLAW_TIMEOUT_SECONDS is NOT already set in the
# shell that launches the celery worker. If you previously started the worker
# from a shell that had this variable exported, kill and relaunch the worker
# from a clean shell after changing this value.
PLANNING_DIRECT_LOCAL_OPENCLAW_TIMEOUT_SECONDS=0

PLANNING_SYNTHESIS_TIMEOUT_SECONDS=180
REPLAN_SYNTHESIS_TIMEOUT_SECONDS=45

# Direct planning repair does not use a PLANNING_REPAIR_BACKEND variable. It
# uses the OpenAI-compatible endpoint/model/key above.
#
# For llama.cpp mode, usually point repair at the same endpoint:
#   PLANNING_REPAIR_BASE_URL=http://host.docker.internal:8001/v1
#   PLANNING_REPAIR_MODEL=local
#   PLANNING_REPAIR_API_KEY=dummy

# Optional bounded debug-repair direct endpoint. Blank base/model/key values
# fall back to PLANNING_REPAIR_BASE_URL, PLANNING_REPAIR_MODEL, and
# PLANNING_REPAIR_API_KEY.
#
# OpenAI Responses API example:
#   DEBUG_REPAIR_BACKEND=openai_responses_api
#   DEBUG_REPAIR_BASE_URL=https://api.openai.com/v1
#   DEBUG_REPAIR_MODEL=gpt-5
#   DEBUG_REPAIR_API_KEY=<your key>
DEBUG_REPAIR_DIRECT_ENABLED=True
DEBUG_REPAIR_BASE_URL=
DEBUG_REPAIR_API_KEY=
DEBUG_REPAIR_DISABLE_THINKING=True


# =============================================================================
# 7. Local Services
# =============================================================================

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

MOBILE_GATEWAY_API_KEY=change-me-shared-secret
MOBILE_BASE_URL=http://127.0.0.1:8080/api/v1

VITE_API_URL=/api/v1
# Leave empty to follow the API host automatically.
VITE_API_WS_HOST=

LOCALHOST=127.0.0.1


# =============================================================================
# 8. Optional Integrations
# =============================================================================

ADMIN_EMAILS=

GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_WEBHOOK_SECRET=

JUDGE_AGENT_ENABLED=False
TRACE_EXPORTER_BACKEND=local_json
LANGFUSE_ENABLED=False


# =============================================================================
# 8b. Planner Relay Browser Session (WF-C)
# =============================================================================

# Host bind address for the browser-session container's noVNC (6080) and CDP
# (9222) ports. Default is loopback-only (127.0.0.1) — both ports grant full,
# unauthenticated control of the persistent Chrome/ChatGPT session
# (x11vnc runs -nopw; CDP has no auth by design). Only widen these to 0.0.0.0
# if you understand and accept exposing that control to your LAN, and never
# on a machine reachable from an untrusted network. Prefer an SSH tunnel for
# remote access instead: see
# docs/roadmap/done/workflow/wf-b-browser-session-runbook.md.
NOVNC_BIND_HOST=127.0.0.1
CDP_BIND_HOST=127.0.0.1

# Expected ChatGPT conversation URL the relay must see before it will send
# (WF-C conversation pinning). Leave blank to skip the check (only do this
# deliberately, e.g. first-time setup before a conversation exists).
RELAY_EXPECTED_CONVERSATION_URL=

# =============================================================================
# 9. Advanced / Compatibility
# =============================================================================

DEMO_MODE=False
ALLOW_TEST_KEYPAIR_ENDPOINT=False
INLINE_PLANNING=False
WORKSPACE_REVIEW_POLICY=hold_nontrivial

ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

LOCAL_OPENCLAW_MAX_PARALLEL_SESSIONS=1
ENABLE_TEST_RUNTIME_BACKENDS=False

# Optional Windows llama.cpp launcher/evidence values.
LLAMA_CTX=
VRAM_LIMIT_MB=

# Legacy or host-only workspace overrides. Prefer WORKSPACE_ROOT.
# HOST_WORKSPACE_ROOT=
# OPENCLAW_WORKSPACE=

# Soft-deleted projects can be purged after this many days. Leave unset to use
# the app default, currently 30.
# SOFT_DELETE_RETENTION_DAYS=30


# =============================================================================
# 10. Feature flags (experimental / off by default)
# =============================================================================

# Inject a single-line structural hint ([Repo] python · pip · src=app/ …) into
# project_context on Task 2+ when repo_memory.json is cached and current.
# Validated 2026-06-08: safe (0 HARMFUL), but USED benefit unproven for
# Python/pytest stacks. Re-enable only after a live A/B confirms USED ≥ 50%.
REPO_MEMORY_INJECTION_ENABLED=False

# Inject WorkingMemory block into project_context on Task 2+.
WORKING_MEMORY_INJECTION_ENABLED=False

# Inject ProjectStateSummary into planning context on Task 2+.
PSS_CONTINUATION_INJECTION_ENABLED=False

# Incremental execution: bypass full planning for creation-only tasks where
# target path, content, and verify command are explicit. Requires ≥ 20 live
# observations and ≥ 70% success rate before broader enablement.
INCREMENTAL_EXECUTION_ENABLED=False